# Database (SQLite by default, switch to Postgres for production)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# S3-Compatible Storage (optional - falls back to local storage)
S3_ENABLED="false"
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""  # Leave empty for AWS S3, set for MinIO/Cloudflare R2/etc.

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Ephemra"
